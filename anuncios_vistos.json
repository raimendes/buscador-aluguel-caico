name: Busca Diaria Caico
on:
  schedule:
    # Roda todos os dias às 11:00 UTC (08:00 da manhã em Caicó/Brasília)
    - cron: '0 11 * * *'
  workflow_dispatch: 

jobs:
  build:
    runs-on: ubuntu-latest
    # PASSO 1: Dar permissão para o robô escrever no seu repositório
    permissions:
      contents: write
      
    steps:
      - name: Baixar codigo do GitHub
        uses: actions/checkout@v3

      - name: Instalar Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: Instalar Chrome e Bibliotecas
        run: |
          pip install selenium webdriver-manager beautifulsoup4 requests

      - name: Rodar o buscador
        env:
          TELEGRAM_TOKEN: ${{ secrets.TELEGRAM_TOKEN }}
          TELEGRAM_CHAT_ID: ${{ secrets.TELEGRAM_CHAT_ID }}
        run: python buscador.py

      # PASSO 2: Comandar o robô para salvar o vistos.json de volta no GitHub
      - name: Salvar links vistos no banco de dados
        run: |
          git config --global user.name "Robo de Caico"
          git config --global user.email "bot@github.com"
          git add vistos.json
          git commit -m "Atualizando links vistos em Caico" || exit 0
          git push
